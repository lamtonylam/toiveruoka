{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": "* 4 * * *",
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Disable all regular package updates",
      "matchPackagePatterns": ["*"],
      "enabled": false
    },
    {
      "description": "Re-enable updates only for known vulnerabilities",
      "matchVulnerabilityAlerts": true,
      "enabled": true
    }
  ]
}
